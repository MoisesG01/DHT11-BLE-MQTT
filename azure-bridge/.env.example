# Copie este arquivo para .env e preencha o valor.
# A connection string do dispositivo você obtém após rodar o script Azure (ver README-AZURE.md).

# Obrigatório: connection string do dispositivo no IoT Hub
# Formato: HostName=xxx.azure-devices.net;DeviceId=esp32-dht11;SharedAccessKey=xxx
IOT_HUB_DEVICE_CONNECTION_STRING=

# Intervalo entre envios para a Azure, em milissegundos (padrão 30000 = 30s; ~2880 msg/dia, dentro do limite de 8000)
# AZURE_SEND_INTERVAL_MS=30000

# Opcional (padrão já aponta para o projeto)
# MQTT_BROKER=mqtt://test.mosquitto.org:1883
# MQTT_TOPIC_TEMP=MOISES/ESP3
# MQTT_TOPIC_HUM=MOISES/ESP3/humidity
